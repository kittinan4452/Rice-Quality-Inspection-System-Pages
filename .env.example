DB_NAME=rice-data
DB_USER=root
DB_PASSWORD=your_password_here
SECRET_KEY=your_secret_key_here

# ===== Email (สำหรับส่งลิงก์รีเซ็ตรหัสผ่าน) =====
# ค่า default เป็น console mode (เมลโผล่ใน log ไม่ส่งจริง)
# ถ้าจะส่งเมลจริงผ่าน Gmail: uncomment แล้วกรอกค่าให้ครบ (ต้องใช้ App Password 16 หลัก)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=youremail@gmail.com
# EMAIL_HOST_PASSWORD=your_16_char_app_password
# DEFAULT_FROM_EMAIL=youremail@gmail.com

# URL ของ frontend (ใช้ประกอบลิงก์ในเมลรีเซ็ตรหัสผ่าน)
FRONTEND_URL=http://localhost:5173
